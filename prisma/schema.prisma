// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// NextAuth Models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?   @unique
  accounts      Account[]
  sessions      Session[]
  profile       Profile?
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Application specific models
model Profile {
  id         String   @id @default(cuid())
  userId     String   @unique
  age        Int?
  gender     String?
  occupation String?
  income     Int?
  category   String?
  state      String?
  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Scheme {
  id                String   @id
  category          String
  title             String   // Stored as JSON string
  shortDescription  String   // Stored as JSON string
  longDescription   String   // Stored as JSON string
  benefitsAmount    String   // Stored as JSON string
  eligibility       String   // Stored as JSON string
  requiredDocuments String   // Stored as JSON string
  applicationUrl    String
  startDate         String?
  endDate           String?
  status            String
  launchedBy        String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
